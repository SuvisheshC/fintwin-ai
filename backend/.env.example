# Secret key for JWT signing - change this in production
SECRET_KEY=fintwin-super-secret-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional: AI provider for the advisor. Leave blank to use rule-based engine only.
# Supported: "openai", "gemini", or leave empty for rule-based only
AI_PROVIDER=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Database
DATABASE_URL=sqlite:///./fintwin.db
